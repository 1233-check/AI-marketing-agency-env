generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("ADMIN")
  createdAt DateTime @default(now())
}

model ContentItem {
  id        String   @id @default(cuid())
  title     String
  type      String   @default("POST") // POST, REEL, STORY
  status    String   @default("PENDING") // PENDING, APPROVED, REJECTED
  body      String
  platform  String   @default("INSTAGRAM") // INSTAGRAM, FACEBOOK, LINKEDIN
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Lead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String   @default("")
  source    String   @default("WEBSITE") // INSTAGRAM, FACEBOOK, EMAIL, WEBSITE
  status    String   @default("NEW") // NEW, CONTACTED, QUALIFIED, CONVERTED
  notes     String   @default("")
  createdAt DateTime @default(now())
}
